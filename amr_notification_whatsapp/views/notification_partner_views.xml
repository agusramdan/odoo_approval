<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_notification_partner_whatsapp_tree" model="ir.ui.view">
        <field name="name">notification.partner.whatsapp.tree</field>
        <field name="model">notification.partner</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="send_whatsapp"/>
                <field name="whatsapp_phone"/>
            </tree>
        </field>
    </record>

    <record id="view_notification_partner_whatsapp_form" model="ir.ui.view">
        <field name="name">notification.partner.whatsapp.form</field>
        <field name="model">notification.partner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="send_whatsapp"/>
                        <field name="whatsapp_phone"/>
                        <field name="whatsapp_message"/>
                    </group>
                    <footer>
                        <button name="action_send_whatsapp" string="Send WhatsApp" type="object" class="oe_highlight"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
