<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="popup_reject_message" model="ir.ui.view">
        <field name="name">popup.reject.message.wizard</field>
        <field name="model">popup.reject.message.wizard</field>
        <field name="arch" type="xml">
            <form string="Message">
                <group>
                    <group>
                        <field name="name" />
                    </group>
                </group>
                <footer>
                    <button name="button_reject" string="Reject" type="object" class="oe_highlight"/>
                    <button string="Cancel" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
