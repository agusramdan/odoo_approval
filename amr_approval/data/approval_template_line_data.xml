<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="approval_template_line" model="approval.template.line">
<!--            <field name="is_primary" eval="True"/>-->
            <field name="model_id" ref="model_approval_task_line"/>
            <!-- agnostic -->

            <field name="auto_register_approval_task" eval="True"/>
            <field name="state_field">status_approval</field>
            <field name="state_approved">approved</field>
            <field name="state_canceled">cancelled</field>
            <field name="state_rejected">rejected</field>
            <field name="state_reset">reset</field>
            <field name="state_waiting_approvals">waiting_approval,waiting</field>

            <!-- reject and approve status will handle in event_approval_done to draft or approved,-->
            <field name="approval_mode">fields</field>
            <field name="approval_mode_function" eval="False"/>
            <field name="approval_mode_fields">user_id,user_ids,group_id,group_ids</field>

            <field name="field_user_execution">user_execution_id</field>
            <field name="field_date_execution">date_execution</field>
            <field name="field_reason">reject_reason</field>
            <field name="field_started_task_time">started_task_time</field>
            <field name="field_user_delegation">user_delegation_id</field>

<!--            <field name="method_start_task">method</field>-->
<!--            <field name="method_set_waiting_approval_state">set_waiting_approval_state</field>-->
<!--            <field name="method_set_approved_state">set_approved_state</field>-->
<!--            <field name="method_set_rejected_state">set_rejected_state</field>-->
<!--            <field name="method_set_canceled_state">set_canceled_state</field>-->
<!--            <field name="method_set_to_draft_state">set_to_draft_state</field>-->

        </record>
    </data>
</odoo>
