<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.cron" id="user_delegate_cron">
        <field name="name">User Delegation Cron</field>
        <field name="model_id" ref="model_user_delegation"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_delegation_state()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">8</field>
        <field name="interval_type">hours</field>
        <field name="nextcall" eval="DateTime.now().strftime('%Y-%m-%d %H:05:00')" />
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>
