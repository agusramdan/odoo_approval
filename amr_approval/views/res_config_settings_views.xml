<odoo>
    <record id="view_config_settings_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.wa</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div id="amr_approval_addons" class="app_settings_block"
                     data-string="amr_approval" string="Approval Addons"
                     data-key="amr_approval_addons" groups="base.group_erp_manager">

                    <div id="amr_approval">
                        <h2>Task Approval</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="module_amr_hr_employee_hierarchy"/>
                                </div>
                                <div class="o_setting_right_pane" >
                                    <div class="content-group">
                                        <label for="module_amr_hr_employee_hierarchy"/>
                                        <div class="text-muted">
                                            Approval Hierarchy on Employee
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>


                </div>
            </xpath>
        </field>
    </record>
</odoo>
