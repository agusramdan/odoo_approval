<odoo>
    <!-- TREE VIEW -->
    <record id="view_approval_matrix_rule_tree" model="ir.ui.view">
        <field name="name">approval.matrix.rule.tree</field>
        <field name="model">approval.matrix.rule</field>
        <field name="arch" type="xml">
            <tree string="Matrix Tiered" default_order="priority">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_approval_matrix_rule_form" model="ir.ui.view">
        <field name="name">approval.matrix.rule.form</field>
        <field name="model">approval.matrix.rule</field>
        <field name="arch" type="xml">
            <form string="Approval Matrix Tiered">
                <header>
                    <field name="active" invisible="1"/>
                    <!--                    <button name="action_try_config"-->
                    <!--                            string="Try Config"-->
                    <!--                            type="object"-->
                    <!--                            class="btn-secondary"/>-->
                </header>
                <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                        attrs="{'invisible': [('active', '=', True)]}"/>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" class="oe_inline"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="requester_group_ids" options="{'no_create': True}" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <!--                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>-->
                        </group>
                    </group>
                    <notebook>
                        <page string="Tiered Config">
                            <field name="approval_matrix_rule_line">
                                <tree editable="bottom" open_form_view="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="type_approval"/>
                                    <field name="group_ids" widget="many2many_tags"
                                           attrs="{'invisible': [('type_approval', '!=', 'group')]}"/>
                                    <field name="model_id" attrs="{'invisible': [('type_approval', '!=', 'model')]}"/>
                                    <field name="condition_select"/>
                                    <field name="condition_range"
                                           attrs="{'invisible': [('condition_select', 'not in', ['tiring','limit','range'])]}"/>
                                    <field name="condition_range_min"
                                           attrs="{'invisible': [('condition_select', 'not in', ['tiring','range'])]}"/>
                                    <field name="condition_range_max"
                                           attrs="{'invisible': [('condition_select', 'not in', ['limit','range'])]}"/>
                                    <button
                                            name="action_open_line"
                                            type="object"
                                            icon="fa-external-link"
                                    />
                                    <!--                                    <button name="action_open_condition_editor" string="Editor" type="object" class="oe_highlight" attrs="{'invisible': [('condition_select', '!=', 'python')]}"/>-->
                                    <field name="reject_to_method" optional="hide"/>
                                    <field name="reject_to_line_id" optional="hide"/>
                                </tree>

                            </field>
                        </page>
                        <page string="Condition">
                            <group>
                                <field name="condition_select"/>
                            </group>
                            <group attrs="{'invisible': [('condition_select', 'not in', ['tiring','limit','range'])]}">
                                <field name="condition_range"/>
                                <field name="condition_range_min"
                                       attrs="{'invisible': [('condition_select', 'not in', ['tiring','range'])]}"/>
                                <field name="condition_range_max"
                                       attrs="{'invisible': [('condition_select', 'not in', ['limit','range'])]}"/>
                            </group>
                            <group attrs="{'invisible': [('condition_select', '!=', 'python')]}">
                                <field name="condition_python" nolabel="1" colspan="4"/>
                            </group>
                            <!--                            <separator string="Test"/>-->
                            <!--                            <group>-->
                            <!--                                <field name="test_value"/>-->
                            <!--                                <field name="test_result" readonly="1"/>-->
                            <!--                            </group>-->
                        </page>
                        <page string="Description">
                            <field name="note"/>
                        </page>

                    </notebook>
                </sheet>
                <footer/>
            </form>
        </field>
    </record>

    <record id="view_approval_matrix_rule_line_form" model="ir.ui.view">
        <field name="name">approval.matrix.rule.line.form</field>
        <field name="model">approval.matrix.rule.line</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" class="oe_inline"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="type_approval"/>
                            <field name="group_ids" widget="many2many_tags" attrs="{'invisible': [('type_approval', '!=', 'group')]}"/>
                            <field name="model_id" attrs="{'invisible': [('type_approval', '!=', 'model')]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Condition">
                            <group>
                                <field name="condition_select"/>
                            </group>
                            <group attrs="{'invisible': [('condition_select', 'not in', ['tiring','limit','range'])]}">
                                <field name="condition_range"/>
                                <field name="condition_range_min"  attrs="{'invisible': [('condition_select', 'not in', ['tiring','range'])]}"/>
                                <field name="condition_range_max" attrs="{'invisible': [('condition_select', 'not in', ['limit','range'])]}"/>
                            </group>
                            <group attrs="{'invisible': [('condition_select', '!=', 'python')]}">
                                <field name="condition_python" nolabel="1" colspan="4"/>
                            </group>
                        </page>
                        <page string="Test">
                            <!--                            <separator string="Test"/>-->
                            <!--                            <group>-->
                            <!--                                <field name="test_value"/>-->
                            <!--                                <field name="test_result" readonly="1"/>-->
                            <!--                            </group>-->
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_approval_matrix_rule" model="ir.actions.act_window">
        <field name="name">Approval Matrix Tiered</field>
        <field name="res_model">approval.matrix.rule</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your Approval Matrix Tiered
            </p>
        </field>
    </record>

</odoo>
