<odoo>

    <record id="view_approval_task_line_tree" model="ir.ui.view">
        <field name="name">approval.task.line.tree</field>
        <field name="model">approval.task.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="id" optional="hide"/>
                <field name="display_name" string="Description"/>
                <field name="status_approval"/>
                <field name="date_execution" />
                <field name="user_execution_id" />
                <field name="reject_reason" optional="hide"/>
                <field name="sign_title" optional="hide"/>
                <field name="access_approval" optional="hide"/>
                <field name="requester_id" optional="hide"/>
                <field name="company_id" optional="hide"/>
                <field name="transaction_id" optional="hide"/>
                <field name="transaction_model_name" optional="hide"/>
                <field name="reject_to_method" optional="hide"/>
                <field name="type_approval" optional="hide"/>
                <field name="user_id" readonly="1" optional="hide" groups="base.group_no_one"/>
                <field name="group_id" readonly="1" optional="hide" groups="base.group_no_one"/>
                <field name="user_ids" widget="many2many_tags" optional="hide" groups="base.group_no_one"/>
                <field name="group_ids" widget="many2many_tags" optional="hide" groups="base.group_no_one"/>
                <field name="started_task_time" readonly="1" optional="hide"/>
                <field name="responsible_user_id" readonly="1" optional="hide"/>
                <field name="approval_instance_id" readonly="1" optional="hide" groups="base.group_no_one"/>
                <field name="approval_user_ids" string="Approval User" widget="many2many_tags" optional="hide" groups="base.group_no_one"/>
                <field name="user_execution_id" readonly="1" optional="hide"/>
                <field name="user_delegation_id" readonly="1" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_approval_task_line_form" model="ir.ui.view">
        <field name="name">approval.task.line.form</field>
        <field name="model">approval.task.line</field>
        <field name="arch" type="xml">
            <form string="Approval Task Line">
                <header>
                    <button name="action_assignment" type="object" string="Assignment"
                            class="oe_highlight" groups="base.group_system"
                    />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" placeholder="Name . . ." readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="type_approval" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="user_ids" readonly="1" widget="many2many_tags"/>
                            <field name="group_id" readonly="1"/>
                            <field name="group_ids" readonly="1" widget="many2many_tags"/>
                            <field name="requester_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="reject_to_method" readonly="1"/>
                            <field name="requester_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Action" >
                            <field name="responsible_user_id" readonly="1"/>
                            <field name="user_execution_id" readonly="1"/>
                            <field name="user_delegation_id" readonly="1"/>
                        </page>
                    </notebook>
                    <footer/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_approval_task_line_action" model="ir.actions.act_window">
        <field name="name">Approval Task Line</field>
        <field name="res_model">approval.task.line</field>
        <field name="view_mode">tree</field>
        <field name="context">{'create': 0,'edit': 0,'delete': 0}</field>
    </record>

</odoo>
