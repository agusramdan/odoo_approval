<odoo>
    <record id="view_approval_template_line_search" model="ir.ui.view">
        <field name="name">approval.template.line.search</field>
        <field name="model">approval.template.line</field>
        <field name="arch" type="xml">
            <search string="Search Approval Template Line">

                <field name="model_id"/>
                <field name="approval_template_id"/>
                <field name="approval_mode"/>

                <separator/>

                <filter string="Auto Register"
                        name="auto_register"
                        domain="[('auto_register_approval_task','=',True)]"/>

                <group expand="0" string="Group By">
                    <filter string="Model" name="group_by_model_id"
                            context="{'group_by':'model_id'}"/>
                    <filter string="Template" name="group_by_approval_template_id"
                            context="{'group_by':'approval_template_id'}"/>
                    <filter string="Parent Mode" name="group_by_parent_mode"
                            context="{'group_by':'parent_mode'}"/>
                    <filter string="Approval Mode" name="group_by_approval_mode"
                            context="{'group_by':'approval_mode'}"/>
                </group>

            </search>
        </field>
    </record>

    <record id="view_approval_template_line_form" model="ir.ui.view">
        <field name="name">approval.template.line.form</field>
        <field name="model">approval.template.line</field>
        <field name="arch" type="xml">
            <form string="Approval Template Line">
                <sheet>
                    <group>
                        <group string="General Configuration">
                            <field name="model_id"/>
                            <field name="auto_register_approval_task"/>
                            <field name="parent_mode"/>
                            <field name="approval_template_id"
                                   attrs="{'invisible':[('parent_mode','=','agnostic')],
                                           'required':[('parent_mode','=','specific')]}"/>
                            <field name="parent_model_id" readonly="1"/>
                            <field name="parent_filed"
                                   attrs="{'invisible':[('parent_mode','=','agnostic')],
                                           'required':[('parent_mode','=','specific')]}"
                            />
                            <field name="approval_mode"/>
                                <field name="approval_mode_function"
                                       attrs="{'invisible':[('approval_mode','!=','function')]}"/>
                                <field name="approval_mode_fields"
                                       attrs="{'invisible':[('approval_mode','!=','fields')]}"/>
                        </group>
                        <group string="Approval Field" >
                            <field name="field_user_execution"/>
                            <field name="field_date_execution"/>
                            <field name="field_user_delegation"/>
                            <field name="field_started_task_time"/>
                        </group>
                        <group string="Approval State Mapping">
                            <field name="state_field"/>
                            <field name="state_waiting_approvals"/>
                            <field name="state_approved"/>
                            <field name="state_rejected"/>
                            <field name="state_canceled"/>
                        </group>
                        <group string="Approval Method>" >
                            <field name="method_start_task"/>
                            <field name="method_set_waiting_approval_state"/>
                            <field name="method_set_approved_state"/>
                            <field name="method_set_rejected_state"/>
                            <field name="method_set_canceled_state"/>
                            <field name="method_set_to_draft_state"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_approval_template_line_tree" model="ir.ui.view">
        <field name="name">approval.template.line.tree</field>
        <field name="model">approval.template.line</field>
        <field name="arch" type="xml">
            <tree string="Approval Template Lines">
                <field name="model_id"/>
                <field name="parent_mode"/>
                <field name="approval_template_id"/>
                <field name="approval_mode"/>
                <field name="state_field"/>
                <field name="auto_register_approval_task"/>
            </tree>
        </field>
    </record>

    <record id="action_approval_template_line" model="ir.actions.act_window">
        <field name="name">Approval Template Lines</field>
        <field name="res_model">approval.template.line</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_approval_template_line_search"/>
    </record>

    <record id="action_approval_template_line_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_approval_template_line_tree"/>
        <field name="act_window_id" ref="action_approval_template_line"/>
    </record>

    <record id="action_approval_template_line_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_approval_template_line_form"/>
        <field name="act_window_id" ref="action_approval_template_line"/>
    </record>
</odoo>
