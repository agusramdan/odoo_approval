<odoo>
    <record id="view_approval_audit_log_tree" model="ir.ui.view">
        <field name="name">approval.audit.log.tree</field>
        <field name="model">approval.audit.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="transaction_display_name" />
                <field name="user_id"/>
                <field name="job_position" optional="hide"/>
                <field name="delegator_id" optional="hide"/>
                <field name="delegator_job_position" optional="hide"/>
                <field name="delegatee_user_id" optional="hide"/>
                <field name="delegatee_job_position" optional="hide"/>
                <field name="action_type"/>
                <field name="create_date"/>
                <field name="notes"/>
            </tree>
        </field>
    </record>

    <record id="view_approval_audit_log_action" model="ir.actions.act_window">
        <field name="name">Approval Audit Log</field>
        <field name="res_model">approval.audit.log</field>
        <field name="view_mode">tree</field>
        <field name="context">{'create': 0,'edit': 0,'delete': 0}</field>
    </record>

    <record model="ir.actions.act_window" id="current_user_approved_action">
        <field name="name">Approved</field>
        <field name="res_model">approval.audit.log</field>
        <field name="view_mode">tree</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'create': 0,'edit': 0,'delete': 0}</field>
    </record>
</odoo>
