<?xml version="1.0"?>
<odoo>
    <data noupdate="1">
        <record id="group_machine" model="res.groups">
            <field name="name">Machine/Client/Service User</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="users" eval="[(4, ref('base.user_root'))]" />
        </record>

        <record id="group_technical" model="res.groups">
            <field name="name">Technical User</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]" />
        </record>

        <record id="user_machine_template" model="res.users">
            <field name="name">Machine User</field>
            <field name="login">machine_user</field>
            <field name="email">machine@system.local</field>

            <!-- penting: non-share = internal system user -->
            <field name="share">False</field>

            <!-- assign group machine -->
            <field name="groups_id" eval="[(4, ref('amr_resource.group_machine'))]"/>
        </record>
    </data>
</odoo>
