<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div id="amr_oidc_addons" class="app_settings_block"
                     data-string="amr_jwt_token" string="OIDC Addons"
                     data-key="amr_oidc_addons" groups="base.group_erp_manager">
                    <div id="amr_resource_config" groups="base.group_erp_manager">
                        <h2>Resource</h2>
                        <div class="row mt16 o_settings_container" id="amr_token_enabled_setting">
                            <div class="col-xs-12 col-md-6 o_setting_box" >
                                <div class="o_setting_right_pane">
                                    <div class="row">
                                        <label for="amr_select_audience" class="col-3 col-lg-3 o_light_label"/>
                                        <field name="amr_select_audience" nolabel="1"/>
                                    </div>
                                    <div class="mt16 row">
                                        <div class="col-9">
                                            <field name="amr_resource_audience" nolabel="1" widget="CopyClipboardChar"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="amr_resource_app">
                        <h2>Token and OIDC</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="module_amr_token"/>
                                </div>
                                <div class="o_setting_right_pane" >
                                    <div class="content-group">
                                        <label for="module_amr_token"/>
                                        <div class="text-muted" id="module_amr_token_description">
                                            Token Provider Server
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xs-12 col-md-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="module_amr_oidc"/>
                                </div>
                                <div class="o_setting_right_pane" >
                                    <div class="content-group">
                                        <label for="module_amr_oidc"/>
                                        <div class="text-muted">
                                            OIDC Server
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="module_amr_signature"/>
                                </div>
                                <div class="o_setting_right_pane" >
                                    <div class="content-module_amr_signature">
                                        <label for="module_amr_signature"/>
                                        <div class="text-muted">
                                            Signature
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="module_amr_auto_login"/>
                                </div>
                                <div class="o_setting_right_pane" >
                                    <div class="content-group">
                                        <label for="module_amr_auto_login"/>
                                        <div class="text-muted">
                                            OIDC Client Auto Login (Experimental)
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
