<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.wa</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="amr_notification.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='amr_notification_firebase_setting_box']" position="inside">
                <div class="content-group">
                    <div class="row mt16">
                        <label for="firebase_credentials_id" class="col-lg-3 o_light_label"/>
                        <field name="firebase_credentials_id"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
