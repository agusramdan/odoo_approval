<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.wa</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div id="amr_notification_addons" class="app_settings_block"
                     data-string="amr_notification" string="Notification"
                     data-key="amr_notification_addons" groups="base.group_erp_manager">

                    <div id="amr_notification">
                        <h2>Notification</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="module_amr_notification_firebase"/>
                                </div>
                                <div class="o_setting_right_pane" id="amr_notification_firebase_setting_box">
                                    <div class="content-group" >
                                        <label for="module_amr_notification_firebase"/>
                                        <div class="text-muted">
                                            Notification Firebase
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xs-12 col-md-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="module_amr_notification_whatsapp"/>
                                </div>
                                <div class="o_setting_right_pane" id="amr_notification_whatsapp_setting_box">
                                    <div class="content-group" >
                                        <label for="module_amr_notification_whatsapp"/>
                                        <div class="text-muted">
                                            Notification Whatsapp
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xs-12 col-md-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="module_amr_notification_telegram"/>
                                </div>
                                <div class="o_setting_right_pane" id="amr_notification_telegram_setting_box">
                                    <div class="content-group" >
                                        <label for="module_amr_notification_telegram"/>
                                        <div class="text-muted">
                                            Notification Telegram
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
