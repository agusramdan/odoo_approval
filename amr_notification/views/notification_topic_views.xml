<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_notification_topic_tree" model="ir.ui.view">
        <field name="name">notification.topic.tree</field>
        <field name="model">notification.topic</field>
        <field name="arch" type="xml">
            <tree>
                <field name="topic"/>
                <field name="condition"/>
                <field name="title"/>
                <field name="state"/>
                <field name="retry_count"/>
                <field name="processed_at"/>
            </tree>
        </field>
    </record>

    <record id="view_notification_topic_form" model="ir.ui.view">
        <field name="name">notification.topic.form</field>
        <field name="model">notification.topic</field>
        <field name="arch" type="xml">
            <form>

                <header>
                    <button name="action_process_notification"
                            string="Process Notification"
                            type="object"
                            class="oe_highlight"
                            states="pending,failed"
                            groups="base.group_erp_manager"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="pending,processing,sent,failed"/>
                </header>

                <sheet>

                    <group>
                        <group>
                            <field name="topic"/>
                            <field name="condition" />
                        </group>
                        <group>
                            <field name="processed_at" readonly="1"/>
                            <field name="retry_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="notification" string="Notification">
                            <group>
                                <field name="title"/>
                                <field name="body"/>
                                <field name="image"/>
                            </group>
                        </page>
                        <page string="Raw Payload">
                            <field name="raw_payload"
                                   widget="text"/>
                        </page>

                        <page string="Data">
                            <field name="data_json"
                                   widget="text"/>
                        </page>

                        <page string="Error">
                            <field name="error_message"
                                   readonly="1"
                                   widget="text"/>
                        </page>

                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <record id="view_notification_topic_search" model="ir.ui.view">
        <field name="name">notification.topic.search</field>
        <field name="model">notification.topic</field>
        <field name="arch" type="xml">
            <search>

                <field name="topic"/>
                <field name="title"/>

                <separator/>

                <filter name="pending"
                        string="Pending"
                        domain="[('state','=','pending')]"/>

                <filter name="processing"
                        string="Processing"
                        domain="[('state','=','processing')]"/>

                <filter name="sent"
                        string="Sent"
                        domain="[('state','=','sent')]"/>

                <filter name="failed"
                        string="Failed"
                        domain="[('state','=','failed')]"/>

            </search>
        </field>
    </record>

    <record id="action_notification_topic" model="ir.actions.act_window">
        <field name="name">Topic</field>
        <field name="res_model">notification.topic</field>
        <field name="view_mode">tree,form</field>
    </record>


</odoo>
