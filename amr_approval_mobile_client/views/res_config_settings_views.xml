        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="amr_approval.view_config_settings_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='amr_approval_mobile_client_content_group']" position="inside">
                <div class="mt16 row">
                     <label for="mobile_approval_server_auth_id" string="Approval Server" class="col-3 col-lg-3 o_light_label"/>
                    <field name="mobile_approval_server_auth_id" nolabel="1"/>
                </div>
                <div class="mt16 row">
                     <label for="mobile_notification_server_auth_id" string="Notification Server" class="col-3 col-lg-3 o_light_label"/>
                    <field name="mobile_notification_server_auth_id" nolabel="1"/>
                </div>




