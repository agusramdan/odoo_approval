<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="approval_template" model="approval.template">
<!--            <field name="is_primary" eval="True"/>-->
            <field name="model_id" ref="amr_esign_pdf.model_pdf_document"/>

            <field name="approval_task_line_model_id" ref="amr_esign_pdf.model_pdf_sign"/>
            <field name="approval_task_line_users_mode">users_field</field>
            <field name="approval_task_line_users_params">user_id</field>
            <field name="approval_task_line_parent_filed">pdf_document_id</field>
            <field name="approval_task_line_state_field">state</field>
<!--            <field name="approval_task_line_state_cancel">cancel</field>-->
<!--            <field name="approval_task_line_state_reject">reject</field>-->
            <field name="approval_task_line_state_approved">signed</field>
            <field name="approval_task_line_state_waiting_approvals">request,draft</field>

            <field name="menu_id" ref="amr_esign_approval.menu_to_approve"/>
            <field name="view_id" ref="amr_esign_approval.view_approval_form"/>
            <field name="action_id" ref="amr_esign_approval.action_to_approve"/>

            <field name="auto_register_approval_task" eval="True"/>
            <field name="state_field">state</field>
            <field name="state_approved">signed</field>
<!--            <field name="state_cancel">cancel</field>-->
<!--            <field name="state_reject">reject</field>-->
            <field name="state_waiting_approvals">request</field>

            <!-- reject and approve status will handle in event_approval_done to draft or approved,-->
            <field name="state_reject" eval="False"/>
            <field name="state_approved" eval="False"/>
            <field name="notes_chatter_rejected" eval="True"/>
            <field name="notification_approval_id" ref="approval_notification_template"/>
            <field name="type_approval_default">multi_group</field>
            <field name="groups_approval_default_ids" eval="[(6,0,[ref('base.group_erp_manager')])]"/>
<!--            <field name="users_approval_default_ids" />-->
            <field name="code">
# skip task line
transaction_requester = transaction_object.users_id
transaction_company = transaction_object.company_id
response['skip_create_approval_task_line'] = True
#response['transaction_value'] = transaction_object.total_cost
#response['transaction_currency'] = transaction_object.currency_id
response['transaction_company'] = transaction_company
response['transaction_requester'] = transaction_requester
            </field>
<!--            <field name="invoke_validate_request_approval">validate_request_approval</field>-->
<!--            <field name="invoke_approval_start">event_approval_start</field>-->
<!--            <field name="invoke_after_approve">event_after_approve</field>-->
<!--            <field name="invoke_approval_done">event_approval_done</field>-->
        </record>
    </data>
</odoo>
